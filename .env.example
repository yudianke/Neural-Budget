# NeuralBudget — environment variables
# Copy to .env and fill in values before running docker-compose up
# DO NOT commit .env to git

# -----------------------------------------------------------------------
# Chameleon Object Store credentials (required for M1/M2/M3 retraining)
# Get these from: https://chi.tacc.chameleoncloud.org -> Identity -> EC2 Credentials
# -----------------------------------------------------------------------
AWS_ACCESS_KEY_ID=replace-with-object-store-access-key
AWS_SECRET_ACCESS_KEY=replace-with-object-store-secret-key

# -----------------------------------------------------------------------
# MLflow tracking server (Chameleon VM)
# -----------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://129.114.27.211:8000

# -----------------------------------------------------------------------
# Grafana
# -----------------------------------------------------------------------
GRAFANA_ROOT_URL=http://localhost:3000
GRAFANA_ADMIN_PASSWORD=neuralbudget

# -----------------------------------------------------------------------
# M2 Anomaly Detection (optional overrides)
# -----------------------------------------------------------------------
# Sensitivity of the IsolationForest (retrain daemon adjusts this automatically)
# M2_CONTAMINATION=0.05

# -----------------------------------------------------------------------
# Moneydata path (M1 retrain daemon — Chameleon VM only)
# On Chameleon: /home/cc/Neural-Budget/training/m1/data/moneydata.csv
# Locally: leave unset (uses /tmp/moneydata_placeholder)
# -----------------------------------------------------------------------
# MONEYDATA_PATH=/home/cc/Neural-Budget/training/m1/data/moneydata.csv
