FROM python:3.10-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

COPY training/m3/requirements_m3.txt /app/requirements_m3.txt
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r /app/requirements_m3.txt && \
    pip install --no-cache-dir requests

COPY training/m3 /app/training/m3

CMD ["python", "training/m3/simulate_production_data.py", "--user-id", "local-user", "--months", "6", "--include-forecast-requests", "--pretty"]