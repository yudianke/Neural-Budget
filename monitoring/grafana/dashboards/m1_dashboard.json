{
  "uid": "neural-budget-m1",
  "title": "NeuralBudget — M1 Categorization",
  "description": "Operational monitoring for the M1 transaction auto-categorization model",
  "tags": ["neural-budget", "m1", "ml-serving"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Model Version",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "mappings": [],
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "targets": [{
        "expr": "m1_model_version_numeric",
        "legendFormat": "Current Version"
      }]
    },
    {
      "id": 2,
      "title": "Request Rate",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "rate(http_requests_total{handler=\"/predict/category\"}[1m])",
        "legendFormat": "req/s"
      }]
    },
    {
      "id": 3,
      "title": "Correction Rate",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "red", "value": 0.4 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "m1_correction_rate",
        "legendFormat": "Correction Rate"
      }]
    },
    {
      "id": 4,
      "title": "Total Predictions",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "purple" }
        }
      },
      "targets": [{
        "expr": "sum(m1_predictions_total)",
        "legendFormat": "Total Predictions"
      }]
    },
    {
      "id": 5,
      "title": "Corrections vs Accepts",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name",
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Corrections" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
          { "matcher": { "id": "byName", "options": "Accepts" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] }
        ]
      },
      "targets": [
        { "expr": "m1_corrections_total", "legendFormat": "Corrections" },
        { "expr": "m1_accepts_total", "legendFormat": "Accepts" }
      ]
    },
    {
      "id": 6,
      "title": "P99 Latency",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{handler=\"/predict/category\"}[5m])) * 1000",
        "legendFormat": "P99 ms"
      }]
    },
    {
      "id": 7,
      "title": "Request Rate Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "expr": "rate(http_requests_total{handler=\"/predict/category\"}[1m])",
          "legendFormat": "Predictions"
        },
        {
          "expr": "rate(http_requests_total{handler=\"/feedback\"}[1m])",
          "legendFormat": "Feedback"
        }
      ]
    },
    {
      "id": 8,
      "title": "Correction Rate Over Time",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "red", "value": 0.4 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "m1_correction_rate",
        "legendFormat": "Correction Rate (rollback triggers at 15% increase)"
      }]
    },
    {
      "id": 9,
      "title": "Predictions by Category",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "options": {
        "orientation": "horizontal",
        "legend": { "displayMode": "none" },
        "tooltip": { "mode": "single" },
        "xTickLabelRotation": 0,
        "barRadius": 0.05
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [{
        "expr": "sort_desc(sum by (predicted_category) (m1_predictions_total))",
        "legendFormat": "{{predicted_category}}"
      }]
    },
    {
      "id": 10,
      "title": "Prediction Confidence Distribution",
      "type": "histogram",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "options": {
        "legend": { "displayMode": "none" },
        "tooltip": { "mode": "single" },
        "fillOpacity": 80,
        "gradientMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      },
      "targets": [{
        "expr": "sum(rate(m1_prediction_confidence_bucket[5m])) by (le)",
        "legendFormat": "{{le}}",
        "format": "heatmap"
      }]
    },
    {
      "id": 11,
      "title": "Latency Percentiles Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{handler=\"/predict/category\"}[5m])) * 1000",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{handler=\"/predict/category\"}[5m])) * 1000",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{handler=\"/predict/category\"}[5m])) * 1000",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "id": 12,
      "title": "Corrections vs Accepts Over Time",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Corrections" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
          { "matcher": { "id": "byName", "options": "Accepts" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] }
        ]
      },
      "targets": [
        { "expr": "rate(m1_corrections_total[5m])", "legendFormat": "Corrections" },
        { "expr": "rate(m1_accepts_total[5m])", "legendFormat": "Accepts" }
      ]
    },

    { "type": "text", "id": 20,
      "title": "── M3 Budget Forecasting ──",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 2 },
      "options": { "mode": "markdown", "content": "## M3 — Budget Forecasting" }
    },
    {
      "id": 21, "title": "M3 Model Version",
      "type": "stat",
      "gridPos": { "x": 0, "y": 30, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "targets": [{ "expr": "m3_model_version_numeric", "legendFormat": "M3 Version" }]
    },
    {
      "id": 22, "title": "M3 Forecast Requests/s",
      "type": "stat",
      "gridPos": { "x": 4, "y": 30, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }] } } },
      "targets": [{ "expr": "rate(http_requests_total{job=\"m3-serving\",handler=\"/forecast/features\"}[1m])", "legendFormat": "req/s" }]
    },
    {
      "id": 23, "title": "M3 P99 Latency",
      "type": "stat",
      "gridPos": { "x": 8, "y": 30, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 500 }, { "color": "red", "value": 2000 }] } } },
      "targets": [{ "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"m3-serving\",handler=\"/forecast/features\"}[5m])) * 1000", "legendFormat": "P99 ms" }]
    },
    {
      "id": 24, "title": "M3 Total Forecasts Served",
      "type": "stat",
      "gridPos": { "x": 12, "y": 30, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "purple" } } },
      "targets": [{ "expr": "sum(m3_predictions_total)", "legendFormat": "Total Forecasts" }]
    },
    {
      "id": 25, "title": "M3 Request Rate Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 34, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "fixed", "fixedColor": "purple" } } },
      "targets": [{ "expr": "rate(http_requests_total{job=\"m3-serving\",handler=\"/forecast/features\"}[1m])", "legendFormat": "Forecast req/s" }]
    },
    {
      "id": 26, "title": "M3 Latency Percentiles",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 34, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } } },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=\"m3-serving\"}[5m])) * 1000", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"m3-serving\"}[5m])) * 1000", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"m3-serving\"}[5m])) * 1000", "legendFormat": "P99" }
      ]
    }
  ]
}
