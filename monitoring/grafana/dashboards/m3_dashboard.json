{
  "uid": "neural-budget-m3",
  "title": "NeuralBudget — M3 Budget Forecasting",
  "description": "Operational monitoring for the M3 monthly budget forecast model",
  "tags": ["neural-budget", "m3", "ml-serving", "forecasting"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Model Version",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" } }
      },
      "targets": [{ "expr": "m3_model_version_numeric", "legendFormat": "Current Version" }]
    },
    {
      "id": 2,
      "title": "Forecast Request Rate",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "rate(http_requests_total{job=\"m3-serving\",handler=\"/forecast/features\"}[1m])",
        "legendFormat": "req/s"
      }]
    },
    {
      "id": 3,
      "title": "P99 Latency",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"m3-serving\",handler=\"/forecast/features\"}[5m])) * 1000",
        "legendFormat": "P99 ms"
      }]
    },
    {
      "id": 4,
      "title": "Total Forecasts Served",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "purple" }
        }
      },
      "targets": [{ "expr": "sum(m3_predictions_total)", "legendFormat": "Total Forecasts" }]
    },
    {
      "id": 5,
      "title": "Service Status",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": {
            "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [{ "expr": "up{job=\"m3-serving\"}", "legendFormat": "m3-serving" }]
    },
    {
      "id": 6,
      "title": "Forecast Request Rate Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [{
        "expr": "rate(http_requests_total{job=\"m3-serving\",handler=\"/forecast/features\"}[1m])",
        "legendFormat": "Forecast req/s"
      }]
    },
    {
      "id": 7,
      "title": "Latency Percentiles Over Time",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=\"m3-serving\"}[5m])) * 1000",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"m3-serving\"}[5m])) * 1000",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"m3-serving\"}[5m])) * 1000",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "id": 8,
      "title": "Forecasts by Category Count",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      },
      "targets": [{
        "expr": "rate(m3_predictions_total[5m])",
        "legendFormat": "n={{n_categories}} categories"
      }]
    },
    {
      "id": 9,
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [{
        "expr": "rate(http_requests_total{job=\"m3-serving\",status=~\"5..\"}[5m]) / rate(http_requests_total{job=\"m3-serving\"}[5m])",
        "legendFormat": "Error Rate"
      }]
    }
  ]
}
